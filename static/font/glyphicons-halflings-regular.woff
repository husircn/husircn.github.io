<script>
		$(function(){
			//大图
		    var bannerswiper = new Swiper('.banner .swiper-container', {
			    speed:800,
			    effect : 'fade',
			    loop:true,
			    autoplay : {
				   delay:5000
				},
			    disableOnInteraction: false,
			   	pagination: {
				    el: '.banner .swiper-pagination',
				    clickable :true,
				},
				on:{
			      	init: function(){
				        swiperAnimateCache(this);
				        swiperAnimate(this);
			      	}, 
			      	slideChangeTransitionEnd: function(){ 
			        	swiperAnimate(this);
		      		} 
			    }
			})
			function view(){
				$('.content').css({"padding-top":$(window).height()+"px"});
			}
			view();
			$(window).resize(function(){
				view();
			})
			var text1swiper = new Swiper('.text-1 .swiper-container', {
				slidesPerView : 4,
				speed:800,
			    autoplay : {
				   delay:5000
				},
			    spaceBetween : 30,
			    disableOnInteraction: false,
				breakpoints: {
			        1199: {
			            slidesPerView: 4
			        },
			        991: {
			            slidesPerView: 2,
			            spaceBetween : 20
			        }
			    }
			})
			if( $(window).width() >= 992 ){
				//空间
				var p2swiper = new Swiper('.picture-2 .swiper-container', {
					slidesPerView : 3,
					speed:800,
				    autoplay : {
					   delay:5000
					},
				    spaceBetween : 1,
				    slidesPerColumn : 2,
					slidesPerColumnFill : 'row',
				    disableOnInteraction: false
				})
			}
			//案例
			var p3swiper = new Swiper('.picture-3 .swiper-container', {
				slidesPerView : 4,
				speed:800,
			    autoplay : {
				   delay:5000
				},
			    spaceBetween : 1,
			    disableOnInteraction: false,
				breakpoints: {
					1199: {
			            slidesPerView : 3,
			        },
			        991: {
			        	spaceBetween : 20,
			            slidesPerView: 2,
			            slidesPerColumn : 2,
						slidesPerColumnFill : 'row'
			        }
			    }
			})
			//主创团队
			var p4swiper = new Swiper('.picture-4 .swiper-container', {
				speed:800,
			    autoplay : {
				   delay:5000
				},
			    disableOnInteraction: false,
				navigation: {
				    nextEl: '.picture-4 .swiper-button-next',
				    prevEl: '.picture-4 .swiper-button-prev',
				}
			})
			//研究于文化与个性的设计和探索
			var text4swiper = new Swiper('.text-4 .swiper-container', {
				slidesPerView : 4,
				speed:800,
			    autoplay : {
				   delay:5000
				},
			    disableOnInteraction: false,
				breakpoints: {
			        991: {
			            slidesPerView: 2,
			            slidesPerColumn : 2,
						slidesPerColumnFill : 'row'
			        }
			    }
			})
			//研究工作室
			var p1swiper = new Swiper('.picture-1 .swiper-container', {
				slidesPerView : 'auto',
				speed:800,
				spaceBetween : -65,
			    disableOnInteraction: false,
